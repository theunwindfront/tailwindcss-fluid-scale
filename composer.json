{
    "name": "theunwindfront/tailwindcss-fluid-scale",
    "description": "Tailwind CSS v4 plugin for automatic fluid typography and dynamic scale calculations using native clamp().",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sagar Pansuriya",
            "email": "pansuriya.sagar94@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Theunwindfront\\FluidScale\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Theunwindfront\\FluidScale\\FluidScaleServiceProvider"
            ]
        }
    }
}
